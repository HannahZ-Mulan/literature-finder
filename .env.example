# ===========================================
# AI Provider Configuration
# ===========================================
# 选择 AI 提供商 (可选: zhipu, deepseek, openai, claude, ollama, mock)
# 如果不设置，系统会自动检测可用的提供商并按优先级回退
# 回退顺序: zhipu -> deepseek -> openai -> ollama -> mock
AI_PROVIDER=zhipu

# ===========================================
# 方案 1: 智谱 GLM-4 (推荐国内用户)
# ===========================================
# 优点: 国内访问快，价格便宜 (¥0.5/1M tokens)，稳定性好
# 获取 API Key: https://open.bigmodel.cn/
ZHIPU_GLM_API_KEY=your_zhipu_api_key_here

# ===========================================
# 方案 2: DeepSeek (高性价比)
# ===========================================
# 优点: 性价比极高 (¥1-2/1M tokens)，国内访问快
# 获取 API Key: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com  # 可选：自定义 endpoint

# ===========================================
# 方案 3: OpenAI GPT (推荐国外用户)
# ===========================================
# 优点: 效果最好，生态完善
# 缺点: 国内访问需要代理，价格较高
# 获取 API Key: https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # 可选：使用代理

# ===========================================
# 方案 4: Ollama (完全免费，本地运行)
# ===========================================
# 优点: 完全免费，数据隐私
# 缺点: 需要本地部署，消耗电脑资源
# 安装步骤:
#   1. 下载安装: https://ollama.ai
#   2. 运行服务: ollama serve
#   3. 拉取模型: ollama pull qwen2.5:7b
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# ===========================================
# 方案 5: Claude (Anthropic)
# ===========================================
# 优点: 长文本处理能力强，效果好
# 缺点: 价格较高
# 获取 API Key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# 成本对比 (生成 1000 篇中等长度摘要)
# ===========================================
# 智谱 GLM:    ≈ ¥0.50   (推荐国内用户)
# DeepSeek:    ≈ ¥1.00   (高性价比)
# OpenAI GPT:  ≈ ¥7.00   (推荐国外用户)
# Claude:      ≈ ¥21.00  (长文本处理)
# Ollama:      免费       (需要本地资源)
# Mock:        免费       (仅测试用)

# ===========================================
# 推荐配置
# ===========================================
# 个人学习/测试 (免费方案):
#   AI_PROVIDER=ollama  (免费，需要安装 Ollama)
#   或 AI_PROVIDER=mock (完全离线测试)

# 小型项目/商业使用 (国内):
#   AI_PROVIDER=zhipu
#   ZHIPU_GLM_API_KEY=xxx
#
#   # 或使用 DeepSeek 作为备用 (回退启用)
#   DEEPSEEK_API_KEY=xxx

# 小型项目/商业使用 (国外):
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=xxx

# 需要最高质量:
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=xxx

# ===========================================
# 多提供商配置示例 (启用自动回退)
# ===========================================
# 同时配置多个 API key，系统会自动回退
# AI_PROVIDER=zhipu
# ZHIPU_GLM_API_KEY=your_zhipu_key
# DEEPSEEK_API_KEY=your_deepseek_key
# OPENAI_API_KEY=your_openai_key
# 当 zhipu 失败时，自动尝试 deepseek -> openai -> mock

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=file:./literature.db

# ===========================================
# 应用配置
# ===========================================
NODE_ENV=development
