# ===========================================
# AI Provider Configuration
# ===========================================
# 选择 AI 提供商 (可选: zhipu, openai, claude, ollama, mock)
# 如果不设置，系统会自动检测可用的提供商
AI_PROVIDER=mock

# 方案 1: 智谱 GLM (推荐国内用户)
# 优点: 国内访问快，价格便宜 (¥0.5/1M tokens)
# 获取 API Key: https://open.bigmodel.cn/
# ZHIPU_GLM_API_KEY=your_zhipu_api_key_here

# 方案 2: OpenAI GPT (推荐国外用户)
# 优点: 效果最好，生态完善
# 缺点: 国内访问需要代理，价格较高
# 获取 API Key: https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # 可选：使用代理

# 方案 3: Ollama (完全免费，本地运行)
# 优点: 完全免费，数据隐私
# 缺点: 需要本地部署，消耗电脑资源
# 安装步骤:
#   1. 下载安装: https://ollama.ai
#   2. 运行服务: ollama serve
#   3. 拉取模型: ollama pull qwen2.5:7b
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# 方案 4: Claude (Anthropic)
# 优点: 长文本处理能力强，效果好
# 缺点: 价格较高
# 获取 API Key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# 成本对比 (生成 1000 篇中等长度摘要)
# ===========================================
# 智谱 GLM:    ≈ ¥0.50  (推荐)
# OpenAI GPT:  ≈ ¥7.00
# Claude:      ≈ ¥21.00
# Ollama:      免费    (需要本地资源)
# Mock:        免费    (仅测试用)

# ===========================================
# 推荐配置
# ===========================================
# 个人学习/测试:
#   AI_PROVIDER=ollama  (免费，需要安装 Ollama)
#   或 AI_PROVIDER=mock (完全离线测试)

# 小型项目/商业使用:
#   AI_PROVIDER=zhipu
#   ZHIPU_GLM_API_KEY=xxx

# 需要最高质量:
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=xxx
